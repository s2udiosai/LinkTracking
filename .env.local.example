# Google Sheets — paste the entire contents of your service account JSON key here (as one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# The ID of your Google Sheet (found in the sheet URL between /d/ and /edit)
SPREADSHEET_ID=your-spreadsheet-id-here

# Your admin password — pick anything you like
ADMIN_PASSWORD=change-me-to-something-strong

# ipinfo.io token — sign up free at https://ipinfo.io/signup
IPINFO_TOKEN=your-ipinfo-token-here

# The public URL of your deployed app (no trailing slash). Used to build tracking URLs in the UI.
# Leave blank for local development; set this on Vercel as an env var.
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
